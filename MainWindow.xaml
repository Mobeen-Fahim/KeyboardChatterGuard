<Window x:Class="KeyboardChatterGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="KeyboardChatterGuard" 
        Icon="app.ico"
        Height="630" Width="960"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#121220"/>
            <Setter Property="BorderBrush" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#121220"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C1C2D"/>
                    <Setter Property="Foreground" Value="#00F2FE"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#252538"/>
                    <Setter Property="Foreground" Value="#00F2FE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Border Background="{StaticResource BgDarkBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1.5" 
            CornerRadius="16" 
            ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar Column -->
                <ColumnDefinition Width="220" />
                <!-- Content Column -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ================= SIDEBAR ================= -->
            <Border Grid.Column="0" Background="#0C0C12" BorderBrush="#1C1C28" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="60" />
                    </Grid.RowDefinitions>

                    <!-- App Logo & Branding -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <!-- Shield Vector Path -->
                        <Path Data="M12,2L2,7V14C2,19.5 7.7,22 12,22C16.3,22 22,19.5 22,14V7L12,2M12,20C8.5,19.1 4,16.5 4,14V8.3L12,4.7L20,8.3V14C20,16.5 15.5,19.1 12,20Z" 
                              Fill="{StaticResource AccentGradientBrush}" 
                              Width="26" Height="26" 
                              Stretch="Uniform" 
                              Margin="0,0,10,0" />
                        <TextBlock Text="Chatter" 
                                   FontFamily="{StaticResource MainFont}" 
                                   FontWeight="Bold" 
                                   FontSize="20" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Guard" 
                                   FontFamily="{StaticResource MainFont}" 
                                   FontWeight="Light" 
                                   FontSize="20" 
                                   Foreground="{StaticResource AccentCyanBrush}" 
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0"/>
                    </StackPanel>

                    <!-- Navigation Items -->
                    <StackPanel Grid.Row="1" Margin="10,20,10,0">
                        <Button x:Name="BtnDashboard" Content="Dashboard" Style="{StaticResource ModernButtonStyle}" Height="40" Margin="0,0,0,8" Click="NavButton_Click" HorizontalContentAlignment="Left" Padding="16,0" Tag="Dashboard"/>
                        <Button x:Name="BtnDevices" Content="Keyboards" Style="{StaticResource ModernButtonStyle}" Height="40" Margin="0,0,0,8" Click="NavButton_Click" HorizontalContentAlignment="Left" Padding="16,0" Tag="Devices"/>
                        <Button x:Name="BtnChatter" Content="Chatter Debounce" Style="{StaticResource ModernButtonStyle}" Height="40" Margin="0,0,0,8" Click="NavButton_Click" HorizontalContentAlignment="Left" Padding="16,0" Tag="Chatter"/>
                        <Button x:Name="BtnSettings" Content="Settings" Style="{StaticResource ModernButtonStyle}" Height="40" Margin="0,0,0,8" Click="NavButton_Click" HorizontalContentAlignment="Left" Padding="16,0" Tag="Settings"/>
                    </StackPanel>

                    <!-- Sidebar Footer -->
                    <TextBlock Grid.Row="2" 
                               x:Name="TxtFooterStatus"
                               Text="v1.0.0 • Connected" 
                               FontFamily="{StaticResource MainFont}" 
                               FontSize="11" 
                               Foreground="{StaticResource TextMutedBrush}" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ================= MAIN CONTENT ================= -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <!-- Custom Title Bar -->
                    <RowDefinition Height="45" />
                    <!-- Tab Panel Content -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Custom Title Bar Controls -->
                <Grid Grid.Row="0" Background="Transparent" SnapsToDevicePixels="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               x:Name="TxtHeaderTitle"
                               Text="Dashboard" 
                               FontFamily="{StaticResource MainFont}" 
                               FontWeight="Bold" 
                               FontSize="16" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               VerticalAlignment="Center" 
                               Margin="24,0,0,0" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                        <!-- Minimize Window Button -->
                        <Button Style="{StaticResource ModernButtonStyle}" Width="32" Height="32" Padding="0" Margin="0,0,6,0" BorderThickness="0" Background="Transparent" Click="MinBtn_Click">
                            <Path Data="M20,14H4V12H20V14Z" Fill="{StaticResource TextSecondaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                        <!-- Close/Hide Window Button -->
                        <Button Style="{StaticResource ModernButtonStyle}" Width="32" Height="32" Padding="0" BorderThickness="0" Background="Transparent" Click="CloseBtn_Click">
                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="{StaticResource TextSecondaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ================= TAB CONTENT PANELS ================= -->
                <Grid Grid.Row="1" Margin="24,8,24,24">
                                       <!-- 1. DASHBOARD VIEW -->
                    <Grid x:Name="TabDashboard" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <!-- Active Profile Header -->
                            <RowDefinition Height="Auto" /> <!-- Quick Stats Bar -->
                            <RowDefinition Height="*" />   <!-- Ghost Key Fix -->
                        </Grid.RowDefinitions>

                        <!-- Header status card -->
                        <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,12" BorderBrush="{StaticResource AccentCyanBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtActiveProfileHeader" Text="Global Default Profile" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="TxtActiveProfileStatusSub" Text="Monitoring keyboard inputs and suppressing chatter." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtStatusLabel" Text="ACTIVE" FontWeight="Bold" FontSize="12" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ToggleButton x:Name="TglFilterActive" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Checked="TglFilterActive_Checked" Unchecked="TglFilterActive_Unchecked"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Quick Stats Bar -->
                        <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,16" Padding="16,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Chatter Suppressed:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtChatterBlockedCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                
                                <Separator Grid.Column="1" Background="#2A2A3E" Width="1" Height="20" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Ghost Keys Blocked:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtGhostBlockedCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="#FF4B91" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Ghost Key Fix content (Grid.Row 2) -->
                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="GHOST KEY SUPPRESSION RULES" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                            <!-- Form to Add Ghost Pair -->
                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Configure character pairs to filter out hardware ghosting" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="Trigger:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBox x:Name="TxtGhostTrigger" Width="40" Height="28" Padding="6,4" MaxLength="1" Style="{StaticResource ModernTextBoxStyle}" CharacterCasing="Upper"/>
                                    <TextBlock Text="➔ Ghost:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                    <TextBox x:Name="TxtGhostTarget" Width="40" Height="28" Padding="6,4" MaxLength="1" Style="{StaticResource ModernTextBoxStyle}" CharacterCasing="Upper"/>
                                    <TextBlock Text="Delay:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                    <TextBox x:Name="TxtGhostDelay" Width="45" Height="28" Padding="6,4" MaxLength="3" Style="{StaticResource ModernTextBoxStyle}" PreviewTextInput="NumberValidationTextBox" Text="40"/>
                                    <TextBlock Text="ms" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="2,0,10,0"/>
                                    <Button Content="Add Rule" Style="{StaticResource AccentButtonStyle}" Padding="12,0" Height="28" Click="AddGhostPair_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- Ghost Pairs List -->
                            <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}">
                                <ScrollViewer Style="{StaticResource ModernScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="LstGhostPairs">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#1C1C28" BorderThickness="0,0,0,1" Padding="0,8,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Formula Visual: [A] ➔ [B] -->
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Border Background="#1C1C28" CornerRadius="4" Padding="6,2" BorderBrush="#3F3F5E" BorderThickness="1">
                                                                <TextBlock Text="{Binding TriggerKey}" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                            </Border>
                                                            <TextBlock Text=" ➔ " FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0"/>
                                                            <Border Background="#25151A" CornerRadius="4" Padding="6,2" BorderBrush="#7A2A3E" BorderThickness="1">
                                                                <TextBlock Text="{Binding GhostKey}" FontWeight="Bold" FontSize="11" Foreground="#FF4B91"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="1" Text="{Binding DelayText}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,24,0"/>

                                                        <Button Grid.Column="2" 
                                                                Content="Remove" 
                                                                Style="{StaticResource ModernButtonStyle}" 
                                                                Padding="8,4" 
                                                                FontSize="11" 
                                                                Click="DeleteGhostPair_Click"
                                                                Tag="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- 2. KEYBOARDS VIEW -->
                    <Grid x:Name="TabDevices" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SELECT HARDWARE PROFILE" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Choose which keyboard to monitor. Filters apply to this device configuration." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Refresh List" Style="{StaticResource ModernButtonStyle}" Click="RefreshDevices_Click" VerticalAlignment="Center"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="LstKeyboards">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <!-- Active Neon Animated Border -->
                                            <Border CornerRadius="8" BorderThickness="2" x:Name="GlowBorder">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActiveProfile}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <LinearGradientBrush.RelativeTransform>
                                                            <RotateTransform x:Name="Rotator" CenterX="0.5" CenterY="0.5" Angle="0"/>
                                                        </LinearGradientBrush.RelativeTransform>
                                                        <GradientStop Color="{Binding BrandColor}" Offset="0.0"/>
                                                        <GradientStop Color="{Binding AccentColor}" Offset="0.5"/>
                                                        <GradientStop Color="{Binding BrandColor}" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="Rotator"
                                                                                 Storyboard.TargetProperty="Angle"
                                                                                 From="0" To="360" Duration="0:0:3"
                                                                                 RepeatBehavior="Forever"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>
                                            </Border>

                                            <!-- Main Content Card -->
                                            <Border CornerRadius="8" BorderThickness="1" Background="#121220" Margin="1" Padding="16,12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#2A2A3E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActiveProfile}" Value="True">
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" /> <!-- Brand Badge -->
                                                        <ColumnDefinition Width="*" />    <!-- Name details -->
                                                        <ColumnDefinition Width="Auto" /> <!-- Apply/Active button -->
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Brand Badge Graphic -->
                                                    <Border Grid.Column="0" CornerRadius="6" Padding="10,6" Margin="0,0,16,0" VerticalAlignment="Center" BorderThickness="1" BorderBrush="{Binding BrandColorBrush}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#1C1C2A"/>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path Data="{Binding BrandLogoData}" Fill="{Binding BrandColorBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding Brand}" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Name Details -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding DisplayId}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <!-- Select Action Button -->
                                                    <Button Grid.Column="2" 
                                                            x:Name="BtnSelectDevice" 
                                                            Padding="12,6" 
                                                            VerticalAlignment="Center"
                                                            Tag="{Binding DevicePath}"
                                                            Click="SelectDevice_Click">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                                                <Setter Property="Content" Value="Activate Profile"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActiveProfile}" Value="True">
                                                                        <Setter Property="Content" Value="Active Profile"/>
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- 3. CHATTER DEBOUNCE VIEW -->
                    <Grid x:Name="TabChatter" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Title and Global Slider -->
                        <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="GLOBAL CHATTER DEBOUNCE" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Ignore duplicate keystrokes of the same key if they arrive faster than this speed." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" x:Name="SldGlobalThreshold" Style="{StaticResource ModernSliderStyle}" Minimum="10" Maximum="200" Value="50" ValueChanged="SldGlobalThreshold_ValueChanged"/>
                                    <TextBlock Grid.Column="1" x:Name="TxtGlobalThresholdValue" Text="50 ms" FontWeight="Bold" FontSize="14" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Header and Add Button for Overrides -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="KEY-SPECIFIC OVERRIDES" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Give specific keys custom thresholds (e.g. Spacebar might need a higher limit)." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="TxtOverrideKey" Width="70" Height="28" Padding="6,4" MaxLength="12" Margin="0,0,6,0" Style="{StaticResource ModernTextBoxStyle}" CharacterCasing="Upper" KeyDown="TxtOverrideKey_KeyDown"/>
                                <TextBox x:Name="TxtOverrideMs" Width="50" Height="28" Padding="6,4" MaxLength="3" Margin="0,0,6,0" Style="{StaticResource ModernTextBoxStyle}" PreviewTextInput="NumberValidationTextBox"/>
                                <Button Content="Add Limit" Style="{StaticResource AccentButtonStyle}" Padding="10,0" Height="28" Click="AddOverride_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- Overrides Table -->
                        <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}">
                            <ScrollViewer Style="{StaticResource ModernScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="LstOverrides">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#1C1C28" BorderThickness="0,0,0,1" Padding="0,8,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding KeyName}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding ThresholdText}" FontSize="13" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                                    <Button Grid.Column="2" Content="Delete" Style="{StaticResource ModernButtonStyle}" Padding="8,4" FontSize="11" Tag="{Binding KeyName}" Click="DeleteOverride_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- 5. SETTINGS VIEW -->
                    <Grid x:Name="TabSettings" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <!-- Startup Settings -->
                            <Border Style="{StaticResource GlassCardStyle}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RUN ON WINDOWS STARTUP" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Launch KeyboardChatterGuard automatically when you log into Windows." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="TglLaunchStartup" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Checked="TglLaunchStartup_Checked" Unchecked="TglLaunchStartup_Unchecked"/>
                                </Grid>
                            </Border>

                            <!-- Minimize to Tray Settings -->
                            <Border Style="{StaticResource GlassCardStyle}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="MINIMIZE TO SYSTEM TRAY" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Closing the application dashboard hides it to the system tray instead of exiting." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" x:Name="TglMinimizeTray" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center" Checked="TglMinimizeTray_Checked" Unchecked="TglMinimizeTray_Unchecked"/>
                                </Grid>
                            </Border>

                            <!-- Preferred Auto-Start Keyboard Settings -->
                            <Border Style="{StaticResource GlassCardStyle}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="AUTO-SWITCH TO PREFERRED DEVICE" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Automatically switch active profiles when this keyboard is plugged into the laptop." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="CboPreferredKeyboard" Style="{StaticResource ModernComboBoxStyle}" Height="30" VerticalAlignment="Center" SelectionChanged="CboPreferredKeyboard_SelectionChanged"/>
                                </Grid>
                            </Border>

                            <!-- Factory Reset Panel -->
                            <Border Style="{StaticResource GlassCardStyle}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RESET ALL CONFIGURATIONS" FontSize="14" FontWeight="Bold" Foreground="#FF4B4B"/>
                                        <TextBlock Text="Wipe all settings, keys overrides, and ghost key pairs to restore factory state." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Reset Config" Style="{StaticResource ModernButtonStyle}" BorderBrush="#FF4B4B" Foreground="#FF4B4B" Padding="16,8" VerticalAlignment="Center" Click="ResetConfig_Click"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Live Activity Console (Moved from Dashboard) -->
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="LIVE SYSTEM ACTIVITY LOG" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Clear Logs" Style="{StaticResource ModernButtonStyle}" Padding="10,4" FontSize="11" Click="ClearConsole_Click"/>
                            </Grid>

                            <Border Grid.Row="1" Background="#06060A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                                <ScrollViewer x:Name="ConsoleScrollViewer" Style="{StaticResource ModernScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="LstConsoleLogs" Margin="12" Padding="0,0,0,10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding LogText}" Foreground="{Binding LogColor}" FontFamily="Consolas, monospace" FontSize="12" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
